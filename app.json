{
  "expo": {
    "name": "UnderstandingMyChild",
    "slug": "UnderstandingMyChild",
    "version": "2.4.0",
    "orientation": "portrait",
    "icon": "./assets/appIcons/appIcon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.jstarapps.UnderstandingMyChild",
      "googleServicesFile": "./GoogleService-Info.plist",
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app uses the microphone to allow you to dictate journal entries via speech-to-text.",
        "NSSpeechRecognitionUsageDescription": "This app uses speech recognition to convert your voice into text for your journal entries.",
        "NSPhotoLibraryUsageDescription": "This app requires access to your photo library so you can select and attach photos or videos directly to your journal entries.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/appIcons/appIconNoBackground.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.chris0084.UnderstandingMyChild",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow UnderstandingMyChild to access the microphone.",
          "speechRecognitionPermission": "Allow UnderstandingMyChild to recognize your voice."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/analytics",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "buildReactNativeFromSource": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "65343bd6-feee-44a5-b927-1f30088e7de0"
      }
    }
  }
}